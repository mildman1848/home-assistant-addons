#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
set -euo pipefail

CONFIG_PATH="${CONFIG_PATH:-/data/options.json}"
NEOLINK_CONFIG="${NEOLINK_CONFIG:-/etc/neolink.toml}"
REDACTED_CONFIG="${REDACTED_CONFIG:-/config/neolink.redacted.toml}"
LOG_LEVEL="$(jq -r '.log_level // "info"' "${CONFIG_PATH}")"

mkdir -p "$(dirname "${REDACTED_CONFIG}")" "$(dirname "${NEOLINK_CONFIG}")"

bashio::log.info "Generating Neolink configuration"

toml_string() {
    jq -nr --arg value "$1" '$value | @json'
}

{
    bind="$(jq -r '.bind // "0.0.0.0"' "${CONFIG_PATH}")"
    bind_port="$(jq -r '.bind_port // 8554' "${CONFIG_PATH}")"
    users_count="$(jq '.rtsp_users | length' "${CONFIG_PATH}")"

    printf 'bind = %s\n' "$(toml_string "${bind}")"
    printf 'bind_port = %s\n\n' "${bind_port}"

    if [[ "${users_count}" -gt 0 ]]; then
        jq -c '.rtsp_users[]' "${CONFIG_PATH}" | while read -r user; do
            name="$(jq -r '.name' <<<"${user}")"
            password="$(jq -r '.password' <<<"${user}")"
            printf '[[users]]\n'
            printf 'name = %s\n' "$(toml_string "${name}")"
            printf 'pass = %s\n\n' "$(toml_string "${password}")"
        done
    fi

    jq -c '.cameras[]' "${CONFIG_PATH}" | while read -r camera; do
        name="$(jq -r '.name' <<<"${camera}")"
        username="$(jq -r '.username' <<<"${camera}")"
        password="$(jq -r '.password' <<<"${camera}")"
        address="$(jq -r '.address' <<<"${camera}")"
        stream="$(jq -r '.stream // "both"' <<<"${camera}")"

        printf '[[cameras]]\n'
        printf 'name = %s\n' "$(toml_string "${name}")"
        printf 'username = %s\n' "$(toml_string "${username}")"
        printf 'password = %s\n' "$(toml_string "${password}")"
        printf 'address = %s\n' "$(toml_string "${address}")"
        if [[ "${stream}" != "both" ]]; then
            printf 'stream = %s\n' "$(toml_string "${stream}")"
        fi
        if [[ "${users_count}" -gt 0 ]]; then
            permitted_users="$(jq -c '[.rtsp_users[].name]' "${CONFIG_PATH}")"
            printf 'permitted_users = %s\n' "${permitted_users}"
        fi
        printf '\n'
    done
} > "${NEOLINK_CONFIG}"

chmod 0600 "${NEOLINK_CONFIG}"

# Store a redacted copy for easier support/debugging.
sed -E 's/^(password|pass) = .*/\1 = "REDACTED"/' "${NEOLINK_CONFIG}" > "${REDACTED_CONFIG}"

bashio::log.info "Neolink config generated at ${NEOLINK_CONFIG}"
bashio::log.debug "Configured log level: ${LOG_LEVEL}"
